# Copy to .env and fill in. Without keys the arena runs on deterministic mocks (offline-safe).

# --- Nebius (inference for all harnesses) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
NEBIUS_PRICE_PER_MTOK=0.13

# --- You.com (Research Agent problem) ---
YOU_API_KEY=
YOU_SEARCH_URL=https://ydc-index.io/v1/search

# --- InsForge (production auth + data) ---
INSFORGE_URL=https://wphij32t.us-west.insforge.app
INSFORGE_API_KEY=
INSFORGE_ANON_KEY=

# --- Arena local auth (demo / fallback) ---
ARENA_JWT_SECRET=arena-dev-secret-change-me

# Per-move wall-clock limit (seconds) before a harness forfeits the game.
MOVE_TIMEOUT=15
# Run baseline tournaments on first startup so leaderboards aren't empty.
AUTO_SEED=1
